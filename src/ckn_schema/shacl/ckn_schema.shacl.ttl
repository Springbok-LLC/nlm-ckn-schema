            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path nlm-ckn:percent_total_cells ],
        [ sh:datatype xsd:string ;
            sh:description "A planned process that has the objective to produce information about a material entity (the evaluant) by examining it." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path OBI:0000070 ],
        [ sh:datatype xsd:anyURI ;
