@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

CHEBI:24431 a sh:NodeShape ;
    sh:closed true ;
    sh:description "A chemical entity is a physical entity of interest in chemistry including molecular entities, parts thereof, and chemical substances." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nlm-ckn:ontology_purl ],
        [ sh:datatype xsd:string ;
            sh:description "The name for an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "The official description of something that explains its meaning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path IAO:0000115 ] ;
    sh:targetClass CHEBI:24431 .

PATO:0000001 a sh:NodeShape ;
    sh:closed true ;
    sh:description "A dependent entity that inheres in a bearer by virtue of how the bearer is related to other entities." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The official description of something that explains its meaning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path IAO:0000115 ],
        [ sh:datatype xsd:string ;
            sh:description "The name for an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nlm-ckn:ontology_purl ] ;
    sh:targetClass PATO:0000001 .

UBERON:0000105 a sh:NodeShape ;
    sh:closed true ;
    sh:description "A spatiotemporal region encompassing some part of the life cycle of an organism." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name for an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "The official description of something that explains its meaning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path IAO:0000115 ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nlm-ckn:ontology_purl ] ;
    sh:targetClass UBERON:0000105 .

nlm-ckn:AnatomicalStructurePartOfAnatomicalStructure a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between an anatomical structure and another anatomical structure it is part of." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a part and some whole entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:AnatomicalStructurePartOfAnatomicalStructure .

nlm-ckn:Association a sh:NodeShape ;
    sh:closed true ;
    sh:description "A typed association between two entities, linked by a predicate." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "The predicate of a triple." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "The subject of a triple." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:string ;
            sh:description "The object of a triple." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:Association .

nlm-ckn:BiomarkerCombinationSubclusterOfBinaryGeneSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a biomarker combination and a set of binary genes that its members are a member of." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class SO:0001260 ;
            sh:description "A collection of discontinuous sequences." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:class SO:0001260 ;
            sh:description "A cell type marker gene is a gene that is selectively expressed in cells of a given type and can be reliably used alone or in combination as a canonical characteristic to optimally classify them." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a group and another group it is part of but does not fully constitute." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:BiomarkerCombinationSubclusterOfBinaryGeneSet .

nlm-ckn:CellSetComposedPrimarilyOfCellType a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and a cell type that comprises most or all of the set." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between two material entities in which more than half of the mass of one is made from the other or units of the same type as the other material entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellSetComposedPrimarilyOfCellType .

nlm-ckn:CellSetDatasetIsAboutAnatomicalStructure a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set dataset and an anatomical structure that some of its data pertain to." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:class nlm-ckn:CellSetDataset ;
            sh:description "A dataset that is about cells taken from one or more tissue samples." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A primitive relation that relates an information artifact to an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellSetDatasetIsAboutAnatomicalStructure .

nlm-ckn:CellSetDatasetWasAttributedToPublication a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set dataset and the publication that can be used as a reference for it." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nlm-ckn:CellSetDataset ;
            sh:description "A dataset that is about cells taken from one or more tissue samples." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Attribution is the ascribing of an entity to an agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class IAO:0000311 ;
            sh:description "A document that is the output of a publishing process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellSetDatasetWasAttributedToPublication .

nlm-ckn:CellSetDerivesFromAnatomicalStructure a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and an anatomical structure it was extracted from for analysis." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A relation between two material entities, the new entity and the old entity, in which the new entity begins to exist when the old entity ceases to exist, and the new entity inherits the significant portion of the matter of the old entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellSetDerivesFromAnatomicalStructure .

nlm-ckn:CellSetExactMatchCellSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between two cell sets that are both instances of the same cell type that have been mapped to each other." ;
    sh:ignoredProperties ( rdf:type ) ;
